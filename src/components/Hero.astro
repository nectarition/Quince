<section class="hero">
  <div class="logotype">
    <img class="logotype_content" src="/assets/logotype.png" />
  </div>
</section>

<style lang="scss">
  .hero {
    display: grid;
    grid-template-columns: auto 128px;
    background-image: url('/assets/background.png');
    background-position: right;
    background-size: cover;
    padding: 32px 24px;
    height: 500px;
    transition: height 0.3s ease;
    @media screen and (max-width: 840px) {
      height: calc(64px + 24px * 2);
    }
  }

  .logotype {
    &_content {
      height: 128px;
      transition: height 0.3s ease;
      @media screen and (max-width: 840px) {
        height: 64px;
      }
    }
  }
</style>
